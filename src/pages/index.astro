---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug"

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const last_posts = posts.slice(0, 2);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Bonjour 🪠, </div>
    <div class="text-5xl font-bold">Je suis Axel DUGAT</div>
    <div class="text-3xl py-3 font-bold"></div>
    <div class="py-2">
      <text class="text-lg">
       Lorem ipsum dolor sit amet, consectetur adipiscing elit. Duis placerat lectus sit amet arcu blandit sodales id in ante. Praesent tortor nisl, vestibulum sed elementum sit amet, vulputate eget dolor. Ut convallis rhoncus ante convallis blandit. Vestibulum hendrerit molestie ligula quis aliquet. Maecenas id purus viverra, fermentum libero interdum, ultrices neque. Donec rutrum, nisi id dignissim interdum, lorem urna sodales leo, id pretium sem lectus id sem. In sodales, est vel pellentesque ultrices, nisi nibh vestibulum risus, quis porttitor nibh nunc eu urna. Praesent in nisl eros. Etiam ullamcorper lorem sed volutpat commodo. Nullam odio lacus, mattis quis dapibus id, elementum nec lectus. Ut at porttitor ante, eget dignissim eros. Vivamus sed rutrum augue. Donec porttitor nibh dui, fermentum faucibus erat vulputate at. Aenean sit amet bibendum libero. Nam porta maximus iaculis. Suspendisse justo mauris, lacinia eget rhoncus sit amet, dignissim eget ligula. Aenean at vulputate arcu, id rhoncus ante. Nullam gravida porttitor ligula et commodo. Aliquam tempus metus sit amet consequat ultricies.
      </text>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">Mes derniers projets {"</>"}</div>
  </div>

  <HorizontalCard
    title="Peter et chier"
    img="/1738745510-amou-susu.webp"
    desc="bip bip bloup bloup."
    url="https://korben.info/worldmonitor-dashboard-intelligence-temps-reel.html"
    badge="Reussie"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Morpion"
    img="/morpion.webp"
    desc="Un truc pas fou fait pour les cours avec la présence d'IA en vibe coding comme aime dire les devops"
    url="https://github.com/LaDw6L03/Morpion"
  />

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Mes derniers articles</div>
  </div>

  {
    last_posts.map((post) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={"/blog/" + createSlug(post.data.title, post.slug)}
          target="_self"
          badge={post.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }
</BaseLayout>
