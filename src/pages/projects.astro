---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---


<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div>
    <!-- Première catégorie -->
    <div class="text-3xl w-full font-bold mb-5">
      Développement d'un mini jeu
    </div>
    <HorizontalCard
      title="Morpion"
      img="/morpion.webp"
      desc="Jeux du morpion en C#"
      url="https://github.com/LaDw6L03/Morpion"
      badge="✅"/>
    <!-- Seconde catégorie -->
    <div class="text-3xl w-full font-bold mt-10 mb-5">
      Autres projets
    </div>
    <HorizontalCard
      title="Exemple"
      img="/projet.webp"
      desc="Description du projet"
      url="https://github.com/..."
      badge="✨"/>
  </div>
</BaseLayout>
