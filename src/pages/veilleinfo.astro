---
import BaseLayout from "../layouts/BaseLayout.astro";

let articles: { title: string; link: string; pubDate: string; description: string; category: string[] }[] = [];
let fetchError = false;

function decodeHtmlEntities(text: string): string {
  return text
    .replace(/&#(\d+);/g, (match, dec) => String.fromCharCode(dec))
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&quot;/g, '"')
    .replace(/&apos;/g, "'")
    .replace(/&nbsp;/g, ' ')
    .replace(/&8217;/g, '’')
    .replace(/&8211;/g, '–')
    .replace(/&8212;/g, '—')
    .replace(/&eacute;/g, 'é')
    .replace(/&egrave;/g, 'è')
    .replace(/&agrave;/g, 'à')
    .replace(/&ccedil;/g, 'ç')
    .trim();
}

try {
  const response = await fetch("https://www.it-connect.fr/feed/");
  if (!response.ok) throw new Error(`HTTP ${response.status}`);
  const xml = await response.text();

  const itemRegex = /<item>([\s\S]*?)<\/item>/g;
  let match;

  while ((match = itemRegex.exec(xml)) !== null) {
    const item = match[1];

    const title = item.match(/<title><!\[CDATA\[(.*?)\]\]><\/title>/)?.[1]
      ?? item.match(/<title>(.*?)<\/title>/)?.[1]
      ?? "Sans titre";

    const link = item.match(/<link>(.*?)<\/link>/)?.[1]
      ?? item.match(/<guid[^>]*>(.*?)<\/guid>/)?.[1]
      ?? "#";

    const pubDateRaw = item.match(/<pubDate>(.*?)<\/pubDate>/)?.[1] ?? "";
    const pubDate = pubDateRaw
      ? new Date(pubDateRaw).toLocaleDateString("fr-FR", {
          day: "2-digit",
          month: "long",
          year: "numeric",
        })
      : "";

    const descRaw =
      item.match(/<description><!\[CDATA\[([\s\S]*?)\]\]><\/description>/)?.[1]
      ?? item.match(/<description>([\s\S]*?)<\/description>/)?.[1]
      ?? "";

    let description = decodeHtmlEntities(descRaw)
      .replace(/<[^>]+>/g, "")
      .trim()
      .slice(0, 220);

    const categoryMatches = [...item.matchAll(/<category><!\[CDATA\[(.*?)\]\]><\/category>/g)];
    const category = categoryMatches.map((m) => decodeHtmlEntities(m[1]));

    articles.push({ 
      title: decodeHtmlEntities(title), 
      link, 
      pubDate, 
      description, 
      category 
    });
  }

  // Tri par date (plus récent en premier) + limitation
  articles.sort((a, b) => {
    const dateA = new Date(a.pubDate || 0);
    const dateB = new Date(b.pubDate || 0);
    return dateB.getTime() - dateA.getTime();
  });
  articles = articles.slice(0, 12);

} catch (e) {
  fetchError = true;
  console.error("Erreur veille info:", e);
}
---

<BaseLayout title="Veille Informatique" sideBarActiveItemID="veilleinfo">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold mb-2">Veille Informatique</div>
    <div class="text-sm text-base-content/60 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
        <path d="M5 3a1 1 0 000 2c5.523 0 10 4.477 10 10a1 1 0 102 0C17 8.373 11.627 3 5 3z"/>
        <path d="M4 9a1 1 0 000 2 3 3 0 013 3 1 1 0 102 0 5 5 0 00-5-5zM3 15a2 2 0 114 0 2 2 0 01-4 0z"/>
      </svg>
      Source : <a href="https://www.it-connect.fr" target="_blank" class="link link-hover text-primary">IT-Connect.fr</a>
    </div>
  </div>

  {fetchError && (
    <div class="alert alert-warning mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      </svg>
      <span>Impossible de charger le flux RSS. Vérifiez votre connexion ou réessayez plus tard.</span>
    </div>
  )}

  {!fetchError && articles.length === 0 && (
    <div class="alert alert-info mb-6">
      <span>Aucun article disponible pour le moment.</span>
    </div>
  )}

  <div class="flex flex-col gap-4">
    {articles.map((article) => (
      <a
        href={article.link}
        target="_blank"
        rel="noopener noreferrer"
        class="card bg-base-200 hover:bg-base-300 transition-all duration-200 hover:scale-[101%] hover:shadow-md"
      >
        <div class="card-body py-4 px-5">
          <div class="flex flex-wrap items-start justify-between gap-2">
            <h2 class="card-title text-base font-semibold leading-snug flex-1">
              {article.title}
            </h2>
            {article.pubDate && (
              <span class="text-xs text-base-content/50 whitespace-nowrap shrink-0 mt-1">
                {article.pubDate}
              </span>
            )}
          </div>

          {article.description && (
            <p class="text-sm text-base-content/70 mt-1 line-clamp-2">
              {article.description}…
            </p>
          )}

          {article.category.length > 0 && (
            <div class="flex flex-wrap gap-1 mt-2">
              {article.category.slice(0, 4).map((cat) => (
                <span class="badge badge-outline badge-sm">{cat}</span>
              ))}
            </div>
          )}
        </div>
      </a>
    ))}
  </div>
</BaseLayout>